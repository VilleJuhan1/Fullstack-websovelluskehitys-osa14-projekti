{
  "compilerOptions": {
    "types": ["jest", "node"],
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["tests", "node_modules"]
}
